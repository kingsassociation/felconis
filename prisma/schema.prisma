generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  image     String?  // Added for Avatar Protocol
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  blogs     Blog[]
}

model Blog {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  content     String
  image       String?
  categoryId  String
  category    BlogCategory @relation(fields: [categoryId], references: [id])
  authorId    String
  author      User         @relation(fields: [authorId], references: [id])
  isStatic    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model BlogCategory {
  id    String @id @default(cuid())
  name  String
  slug  String @unique
  blogs Blog[]
}

model CaseStudy {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  clientName   String?
  tag          String?  // E-commerce, SaaS, etc.
  stats        String?  // +220%, 3.2x, etc.
  kpi          String?  // Revenue Acceleration, etc.
  duration     String?
  problem      String
  strategy     String
  execution    String[] // Changed to String[]
  results      String[] // Changed to String[]
  image        String?
  technologies String[]
  createdAt    DateTime @default(now())
}

model Job {
  id               String        @id @default(cuid())
  title            String
  slug             String        @unique
  department       String?
  overview         String?
  description      String        // General description/main content
  salary           String?
  responsibilities String[]
  requirements     String[]
  benefits         String[]
  location         String
  type             String        @default("FULL_TIME")
  active           Boolean       @default(true)
  applications     Application[]
  createdAt        DateTime      @default(now())
}

model Application {
  id          String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id])
  name        String
  email       String
  resume      String
  portfolio   String?
  coverLetter String?
  createdAt   DateTime @default(now())
}

model TeamMember {
  id       String  @id @default(cuid())
  name     String
  role     String
  image    String?
  twitter  String?
  linkedin String?
  bio      String?
  order    Int     @default(0)
}

model Testimonial {
  id          String  @id @default(cuid())
  name        String
  company     String
  photo       String?
  quote       String
  designation String?
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  message   String
  status    String   @default("NEW")
  partnerId String?
  partner   Partner? @relation(fields: [partnerId], references: [id])
  createdAt DateTime @default(now())
}

model Service {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  subtitle    String?
  description String
  image       String?
  icon        String?
  category    String   // SOFTWARE, MARKETING, AI
  highlights  Json?    // Array of objects { title, desc }
  features    String[]
}

model Partner {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  password       String?  // Added for Portal Access
  image          String?  // Added for Avatar Protocol
  phone          String
  whatsapp       String?
  portfolio      String?
  social         String?
  skills         String?
  experience     String?
  status         String   @default("PENDING")
  commissionRate Float?   @default(10.0)
  totalEarned    Float?   @default(0.0)
  leads          Lead[]
  createdAt      DateTime @default(now())
}

model Asset {
  id        String   @id @default(cuid())
  title     String
  category  String   // BRAND_KIT, PRESENTATION, SPECIFICATION
  size      String
  type      String   // ZIP, PDF
  url       String
  status    String   @default("PUBLISHED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
